{
  "title": "AUP Hub Monitoring",
  "tags": ["aup-learning-hub"],
  "schemaVersion": 38,
  "version": 3,
  "panels": [
    {
      "type": "stat",
      "title": "Active Sessions",
      "targets": [{ "expr": "sum(hub_active_sessions)", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Active Users (24h)",
      "targets": [{ "expr": "sum(jupyterhub_active_users{period=\"24h\"})", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Spawn Total",
      "targets": [{ "expr": "sum(hub_spawn_gpu_total)", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Quota Denied",
      "targets": [{ "expr": "sum(hub_quota_denied_total)", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Spawn Rate",
      "targets": [{ "expr": "sum(rate(hub_spawn_gpu_total[5m]))", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Spawn Latency P95 (s)",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(hub_spawn_duration_seconds_bucket[5m])))", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Notebook CPU by Pod (mCPU)",
      "targets": [{ "expr": "1000 * sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"jupyterhub\", pod=~\"jupyter-.*\", cpu=\"total\"}[5m]))", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "Notebook Memory by Pod (MiB)",
      "targets": [{ "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"jupyterhub\", pod=~\"jupyter-.*\"}) / 1024 / 1024", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "Pod Failures by Reason",
      "targets": [{ "expr": "sum by (reason) (rate(hub_pod_failure_total[5m]))", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "targets": [{ "expr": "sum(rate(jupyterhub_request_duration_seconds_count[5m]))", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
    }
  ]
}
