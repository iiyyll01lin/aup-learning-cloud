"""auplc-installer launcher (Python).

Drop-in replacement for the previous bash script. Same CLI surface, same
flags, same env vars, same offline-bundle layout.

Usage:
  ./auplc-installer help
  ./auplc-installer install
  ./auplc-installer tui
  sudo ./auplc-installer install --gpu=strix-halo --courses=basic
  ./auplc-installer pack --gpu=strix-halo

The actual implementation lives in the ``auplc_installer`` Python package
sitting alongside this script (in the same directory). This launcher just
makes that directory importable and dispatches to ``auplc_installer.cli``.

When packed into an offline bundle (``./auplc-installer pack``), both this
launcher and the ``auplc_installer/`` package directory are copied into
the bundle root, so the air-gapped installer is fully self-contained.
"""

from __future__ import annotations

import sys
from pathlib import Path

# Make the bundled package importable when the launcher is run directly
# (e.g. ``./auplc-installer install``) as opposed to ``python3 -m
# auplc_installer install`` which sets up sys.path automatically.
_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from auplc_installer.cli import main  # noqa: E402  (path manipulation must come first)

if __name__ == "__main__":
    main()
